meta {
  name: register
  type: http
  seq: 2
}

post {
  url: {{base_url}}/solana/register/register
}

headers {
  Content-Type: application/json
}

body {
  {}
}

tests {
  test("200 OK - registrant registered", async function() {
    const result = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(result.address).to.be.ok;
    bru.setVar('REGISTRANT_ADDRESS', result.address);
  });
}
