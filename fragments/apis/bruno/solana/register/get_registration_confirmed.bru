meta {
  name: get registration confirmed
  type: http
  seq: 6
}

get {
  url: {{base_url}}/solana/register/{{REGISTRANT_ADDRESS}}
}

headers {
  Content-Type: application/json
}

tests {
  test("200 OK - registration is confirmed", function() {
    const result = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(result.registrant).to.equal(bru.getVar("REGISTRANT_ADDRESS"));
    expect(result.confirmed_at).to.be.ok;
  });
}
