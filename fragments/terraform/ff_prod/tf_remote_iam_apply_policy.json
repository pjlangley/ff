{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SqsQueueLifecycleScoped",
      "Effect": "Allow",
      "Action": [
        "sqs:CreateQueue",
        "sqs:DeleteQueue",
        "sqs:GetQueueAttributes",
        "sqs:SetQueueAttributes",
        "sqs:GetQueueUrl",
        "sqs:TagQueue",
        "sqs:UntagQueue",
        "sqs:ListQueueTags"
      ],
      "Resource": "arn:aws:sqs:eu-west-2:<account_id>:ff_prod_*"
    },
    {
      "Sid": "SqsListAndIdentity",
      "Effect": "Allow",
      "Action": [
        "sqs:ListQueues",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    }
  ]
}
