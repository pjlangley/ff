{
  "model": "claude-opus-4-8",
  "effortLevel": "high",
  "alwaysThinkingEnabled": true,
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["/tmp"]
    },
    "excludedCommands": ["docker"],
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "*github.com",
        "*docs.rs",
        "*raw.githubusercontent.com",
        "*crates.io",
        "*registry.npmjs.org"
      ]
    }
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Read(./solana.id.json)",
      "Edit(./solana.id.json)",
      "Write(./solana.id.json)",
      "Read(./solana_program_keys/solana_deployer.json)",
      "Edit(./solana_program_keys/solana_deployer.json)",
      "Write(./solana_program_keys/solana_deployer.json)",
      "Read(**/*-keypair.json)",
      "Edit(**/*-keypair.json)",
      "Write(**/*-keypair.json)",
      "Read(./fragments/blockchain/solana/scripts/devnet.env)",
      "Edit(./fragments/blockchain/solana/scripts/devnet.env)",
      "Write(./fragments/blockchain/solana/scripts/devnet.env)",
      "Read(./fragments/blockchain/solana/devnet_deployer.id.json)",
      "Edit(./fragments/blockchain/solana/devnet_deployer.id.json)",
      "Write(./fragments/blockchain/solana/devnet_deployer.id.json)",
      "Read(./fragments/blockchain/solana/solana-cli.devnet.yml)",
      "Edit(./fragments/blockchain/solana/solana-cli.devnet.yml)",
      "Write(./fragments/blockchain/solana/solana-cli.devnet.yml)"
    ]
  }
}
